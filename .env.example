# team-claude-kit — required secrets
# Copy to .env.local and fill in values
# DO NOT commit .env.local to git

# GitHub MCP (scope: repo read, pull_requests read)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Sentry MCP (scope: project:read, event:read)
SENTRY_TOKEN=sntrys_...

# Figma MCP (scope: File content read)
FIGMA_TOKEN=figd_...

# Backlog MCP — dùng cho claim system + daily workflow
BACKLOG_DOMAIN=your-space.backlog.com
BACKLOG_API_KEY=your-api-key

# Optional: pin ECC to specific commit
# ECC_COMMIT=abc123def
